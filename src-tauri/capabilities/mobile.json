{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile-capability",
  "description": "Capability for the mobile app",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-app-write-recursive",
    "fs:allow-app-read-recursive",
    "fs:allow-copy-file",
    "allow-all-commands",
    "notification:default",
    "shell:default"
  ]
}
