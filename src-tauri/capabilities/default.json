{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-app-write-recursive",
    "fs:allow-app-read-recursive",
    "fs:allow-copy-file",
    "allow-all-commands",
    "notification:default",
    "shell:default"
  ]
}